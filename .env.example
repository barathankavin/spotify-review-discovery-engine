# Copy to .env and set your keys (never commit .env)
GROQ_API_KEY=

# Hugging Face (local embeddings / sentence-transformers)
# Create a read token at https://huggingface.co/settings/tokens
HF_TOKEN=
# Optional: force offline cache only (no Hub requests) when HF_TOKEN is unset
# HF_HUB_OFFLINE=1

EMBEDDING_BACKEND=local
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

GROQ_CHAT_MODEL=llama-3.3-70b-versatile
GROQ_EMBEDDING_MODEL=nomic-embed-text-v1.5
EMBED_BATCH_SIZE=128
EMBED_BATCH_SLEEP_S=1.0
LOOKBACK_WEEKS=10
PACKAGE_NAME=com.spotify.music
MIN_WORD_COUNT=6
ANALYSIS_SAMPLE_CAP=450
UNMET_NEEDS_SAMPLE_CAP=300
ANALYSIS_BATCH_SIZE=20
GROQ_CALL_SLEEP_S=0.5
# Set true only if you need client-side RPM/TPM throttling (default: off)
GROQ_THROTTLE=false

# RAG chatbot
RAG_USE_GROQ=true
RAG_FALLBACK=true
RAG_TOP_K=8
RAG_SIMILARITY_THRESHOLD=0.30
RAG_MAX_ANSWER_TOKENS=768

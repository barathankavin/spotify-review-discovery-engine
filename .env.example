# Copy to .env and set your keys (never commit .env)
GROQ_API_KEY=

# Hugging Face (local embeddings / sentence-transformers)
# Create a read token at https://huggingface.co/settings/tokens
HF_TOKEN=
# Optional: force offline cache only (no Hub requests) when HF_TOKEN is unset
# HF_HUB_OFFLINE=1

EMBEDDING_BACKEND=local
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

GROQ_CHAT_MODEL=llama-3.3-70b-versatile
GROQ_EMBEDDING_MODEL=nomic-embed-text-v1.5
EMBED_BATCH_SIZE=128
EMBED_BATCH_SLEEP_S=1.0
LOOKBACK_WEEKS=10
# Incremental refresh re-fetches this many days before the last collected date
# (safety overlap to catch late-arriving reviews; merged + deduped by review_id).
INCREMENTAL_OVERLAP_DAYS=3
PACKAGE_NAME=com.spotify.music
MIN_WORD_COUNT=6
ANALYSIS_SAMPLE_CAP=450
UNMET_NEEDS_SAMPLE_CAP=300
ANALYSIS_BATCH_SIZE=20
GROQ_CALL_SLEEP_S=0.5
# Client-side pacing for the analysis batch job to stay under Groq per-minute
# limits (recommended for free tier; avoids 429 bursts + slow backoff).
GROQ_THROTTLE=true
GROQ_RPM_LIMIT=28
GROQ_TPM_LIMIT=11000

# RAG chatbot
RAG_USE_GROQ=true
RAG_FALLBACK=true
RAG_TOP_K=8
RAG_FETCH_K=40
RAG_MMR_LAMBDA=0.7
RAG_SIMILARITY_THRESHOLD=0.30
RAG_MAX_ANSWER_TOKENS=768

# Optional: let the in-app "Refresh pipeline" button trigger the GitHub
# Actions workflow (workflow_dispatch). Needs a PAT with actions:write.
# GH_DISPATCH_TOKEN=
# GH_REPO=barathankavin/spotify-review-discovery-engine
# GH_WORKFLOW_FILE=weekly-refresh.yml
# GH_BRANCH=master

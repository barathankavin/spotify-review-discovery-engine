# Copy to .streamlit/secrets.toml for local testing (never commit secrets.toml).
# On Streamlit Community Cloud, paste these in App Settings → Secrets.

GROQ_API_KEY = ""
HF_TOKEN = ""
EMBEDDING_BACKEND = "local"
LOCAL_EMBEDDING_MODEL = "sentence-transformers/all-MiniLM-L6-v2"
GROQ_CHAT_MODEL = "llama-3.3-70b-versatile"
RAG_TOP_K = "8"
RAG_FETCH_K = "40"
RAG_MMR_LAMBDA = "0.7"
RAG_SIMILARITY_THRESHOLD = "0.30"
RAG_MAX_ANSWER_TOKENS = "768"

# Optional — enable the in-app "Refresh pipeline" button to trigger GitHub Actions.
# GH_DISPATCH_TOKEN = "ghp_..."        # PAT with actions:write
# GH_REPO = "barathankavin/spotify-review-discovery-engine"
# GH_WORKFLOW_FILE = "weekly-refresh.yml"
# GH_BRANCH = "master"
